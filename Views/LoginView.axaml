<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="WatchCollection.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#F5F5F7">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
            Background="White" CornerRadius="16" 
            BoxShadow="0 4 30 0 #20000000" MinWidth="700">
        <Grid ColumnDefinitions="280,*">
            <!-- Image côté gauche -->
            <Border Grid.Column="0" Background="#1B1B2F" CornerRadius="16,0,0,16" Padding="30">
                <StackPanel VerticalAlignment="Center" Spacing="20">
                    <Image Source="{Binding WatchHeroImage}" 
                           Height="180" Stretch="Uniform"
                           IsVisible="{Binding WatchHeroImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="⌚" FontSize="80" HorizontalAlignment="Center" Foreground="#555"
                               IsVisible="{Binding WatchHeroImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                    <TextBlock Text="WatchCollection" FontSize="22" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Gérez votre collection de montres avec élégance" 
                               FontSize="12" Foreground="#8E8E93" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Formulaire côté droit -->
            <Border Grid.Column="1" Padding="40,35">
                <StackPanel Spacing="14" VerticalAlignment="Center">
                    <TextBlock Text="Bienvenue" FontSize="26" FontWeight="Bold" Foreground="#1B1B2F"/>
                    <TextBlock Text="Connectez-vous à votre collection"
                               FontSize="13" Foreground="#8E8E93" Margin="0,0,0,12"/>

                    <!-- Champs inscription -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsRegistering}">
                        <TextBlock Text="Prénom" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding FirstName}" Watermark="Votre prénom"/>
                    </StackPanel>
                    <StackPanel Spacing="4" IsVisible="{Binding IsRegistering}">
                        <TextBlock Text="Nom" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding LastName}" Watermark="Votre nom"/>
                    </StackPanel>

                    <!-- Champs login -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Email" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding Email}" Watermark="email@exemple.com"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Mot de passe" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding Password}" Watermark="Votre mot de passe" PasswordChar="•"/>
                    </StackPanel>

                    <!-- Erreur -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF3B30"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" FontSize="12"/>

                    <!-- Boutons -->
                    <Button Content="Se connecter" Command="{Binding LoginCommand}"
                            IsVisible="{Binding !IsRegistering}" Classes="primary"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            FontSize="14" Margin="0,8,0,0"/>

                    <Button Content="Créer mon compte" Command="{Binding RegisterCommand}"
                            IsVisible="{Binding IsRegistering}" Classes="success"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            FontSize="14" Margin="0,8,0,0"/>

                    <Button Command="{Binding ToggleRegisterCommand}" Classes="ghost"
                            HorizontalAlignment="Center" FontSize="13">
                        <StackPanel>
                            <TextBlock Text="Créer un compte" IsVisible="{Binding !IsRegistering}"/>
                            <TextBlock Text="J'ai déjà un compte" IsVisible="{Binding IsRegistering}"/>
                        </StackPanel>
                    </Button>

                    <!-- Bypass -->
                    <Button Content="Continuer sans compte" Command="{Binding SkipLoginCommand}"
                            IsVisible="{Binding !IsMongoAvailable}"
                            Background="#FF9500" Foreground="White" CornerRadius="8"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="12,10" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

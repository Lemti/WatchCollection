<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="800"
             x:Class="WatchCollection.Views.AddWatchView"
             x:DataType="vm:AddWatchViewModel">

    <UserControl.KeyBindings>
        <!-- Enter : ajoute la montre à la collection -->
        <KeyBinding Gesture="Enter" Command="{Binding AddWatchCommand}"/>
    </UserControl.KeyBindings>

    <Design.DataContext>
        <vm:AddWatchViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="20">
            <!-- En-tête -->
            <StackPanel>
                <TextBlock Text="Ajouter une montre" Classes="title"/>
                <TextBlock Text="Renseignez les informations pour enrichir votre collection"
                           FontFamily="{DynamicResource FontInter}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Carte Scanner USB -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="3" Height="20"
                                Background="{DynamicResource ChampagneGoldBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Scanner USB"
                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                   FontSize="17"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Le scanner se connecte automatiquement à l'ouverture de cette page. Scannez un code-barre pour renseigner le champ Code-barre."
                               FontFamily="{DynamicResource FontInter}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Indicateur de statut du scanner (connexion automatique) -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Pastille verte si connecté -->
                        <Ellipse Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource SuccessForestBrush}"
                                 IsVisible="{Binding IsScannerConnected}"/>
                        <!-- Pastille grise si non connecté -->
                        <Ellipse Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource TextMutedBrush}"
                                 IsVisible="{Binding !IsScannerConnected}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{DynamicResource FontInter}"
                                   FontSize="12"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Carte Formulaire -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="3" Height="20"
                                Background="{DynamicResource ChampagneGoldBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Informations"
                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                   FontSize="17"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="CODE-BARRE" Classes="section"/>
                        <TextBox Text="{Binding Barcode}" Watermark="Scannez ou saisissez manuellement"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="MARQUE *" Classes="section"/>
                            <TextBox Text="{Binding Brand}" Watermark="Rolex, Omega, Patek..."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="MODÈLE *" Classes="section"/>
                            <TextBox Text="{Binding Model}" Watermark="Submariner, Speedmaster..."/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="RÉFÉRENCE" Classes="section"/>
                            <TextBox Text="{Binding Reference}" Watermark="126610LN"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="MOUVEMENT" Classes="section"/>
                            <ComboBox ItemsSource="{Binding MovementOptions}"
                                      SelectedItem="{Binding Movement}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="DIAMÈTRE (mm)" Classes="section"/>
                            <TextBox Text="{Binding Diameter}" Watermark="41"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="MATÉRIAU BOÎTIER" Classes="section"/>
                            <TextBox Text="{Binding CaseMaterial}" Watermark="Acier, Titane, Or..."/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="PRIX (€)" Classes="section"/>
                            <TextBox Text="{Binding Price}" Watermark="9150"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="ANNÉE" Classes="section"/>
                            <TextBox Text="{Binding Year}" Watermark="2024"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="4">
                            <TextBlock Text="STOCK" Classes="section"/>
                            <TextBox Text="{Binding Stock}" Watermark="1"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Ajouter à la collection"
                            Command="{Binding AddWatchCommand}"
                            Classes="primary"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            IsDefault="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
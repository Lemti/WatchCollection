<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="500"
             x:Class="WatchCollection.Views.UsersView"
             x:DataType="vm:UsersViewModel">

    <Design.DataContext>
        <vm:UsersViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="16">
        <TextBlock Text="Utilisateurs" FontSize="28" FontWeight="Bold" Foreground="#1B1B2F"/>
        <TextBlock Text="Gérer les comptes utilisateurs de l'application"
                   FontSize="13" Foreground="#8E8E93"/>

        <Border Background="White" CornerRadius="12" Padding="20" BoxShadow="0 1 4 0 #10000000">
            <StackPanel Spacing="12">
                <TextBlock Text="Nouveau compte" FontWeight="SemiBold" FontSize="15" Foreground="#1B1B2F"/>
                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,Auto">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                        <TextBlock Text="Prénom" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding NewFirstName}" Watermark="Prénom"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                        <TextBlock Text="Nom" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding NewLastName}" Watermark="Nom"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,10,0,0">
                        <TextBlock Text="Email" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding NewEmail}" Watermark="email@exemple.com"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,10,0,0">
                        <TextBlock Text="Mot de passe" FontSize="12" Foreground="#8E8E93"/>
                        <TextBox Text="{Binding NewPassword}" Watermark="Mot de passe" PasswordChar="•"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Créer le compte" Command="{Binding AddUserCommand}" Classes="primary"
                            IsEnabled="{Binding !IsBusy}"/>
                    <Button Content="Rafraîchir" Command="{Binding RefreshUsersCommand}" Classes="ghost"
                            IsEnabled="{Binding !IsBusy}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               Foreground="#8E8E93" FontSize="12" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="12" Padding="20" BoxShadow="0 1 4 0 #10000000">
            <StackPanel Spacing="10">
                <TextBlock Text="Comptes existants" FontWeight="SemiBold" FontSize="15" Foreground="#1B1B2F"/>
                <ListBox ItemsSource="{Binding Users}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F5F5F7" CornerRadius="10" Padding="14" Margin="0,2">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Foreground="#1B1B2F" FontWeight="SemiBold" FontSize="14"
                                                   Text="{Binding DisplayName}"/>
                                        <TextBlock Text="{Binding Email}" Foreground="#8E8E93" FontSize="12"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Background="#FFF4E5" CornerRadius="6"
                                            Padding="10,4" VerticalAlignment="Center" Margin="10,0"
                                            IsVisible="{Binding IsAdminBadge}">
                                        <TextBlock Text="admin" Foreground="#FF9500"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="6"
                                            Padding="10,4" VerticalAlignment="Center" Margin="10,0"
                                            IsVisible="{Binding !IsAdminBadge}">
                                        <TextBlock Text="user" Foreground="#34C759"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>

                                    <Button Grid.Column="2" Content="Supprimer"
                                            Command="{Binding $parent[ListBox].((vm:UsersViewModel)DataContext).DeleteUserCommand}"
                                            CommandParameter="{Binding Email}"
                                            Background="#FFF0F0" Foreground="#FF3B30" Padding="12,6"
                                            CornerRadius="8" FontSize="11"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
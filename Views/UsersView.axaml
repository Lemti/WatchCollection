<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
             x:Class="WatchCollection.Views.UsersView"
             x:DataType="vm:UsersViewModel">

    <Design.DataContext>
        <vm:UsersViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="20">
            <!-- En-tête -->
            <StackPanel>
                <TextBlock Text="Utilisateurs" Classes="title"/>
                <TextBlock Text="Gérer les comptes d'accès à l'application"
                           FontFamily="{DynamicResource FontInter}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Carte : création de compte -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="3" Height="20"
                                Background="{DynamicResource ChampagneGoldBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Nouveau compte"
                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                   FontSize="17"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="PRÉNOM" Classes="section"/>
                            <TextBox Text="{Binding NewFirstName}" Watermark="Prénom"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                            <TextBlock Text="NOM" Classes="section"/>
                            <TextBox Text="{Binding NewLastName}" Watermark="Nom"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
                            <TextBlock Text="EMAIL" Classes="section"/>
                            <TextBox Text="{Binding NewEmail}" Watermark="email@exemple.com"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,12,0,0">
                            <TextBlock Text="MOT DE PASSE" Classes="section"/>
                            <TextBox Text="{Binding NewPassword}" Watermark="Mot de passe" PasswordChar="•"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Content="Créer le compte"
                                Command="{Binding AddUserCommand}"
                                Classes="primary"
                                IsEnabled="{Binding !IsBusy}"/>
                        <Button Content="Rafraîchir"
                                Command="{Binding RefreshUsersCommand}"
                                Classes="secondary"
                                IsEnabled="{Binding !IsBusy}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{DynamicResource FontInter}"
                                   FontStyle="Italic"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Carte : liste des comptes -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="3" Height="20"
                                Background="{DynamicResource ChampagneGoldBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Comptes existants"
                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                   FontSize="17"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Users}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource IvoryBrush}"
                                        CornerRadius="10"
                                        Padding="16" Margin="0,3">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <!-- Infos utilisateur -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                                       FontSize="15"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Email}"
                                                       FontFamily="{DynamicResource FontInter}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Badge admin -->
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource ChampagneGoldBrush}"
                                                CornerRadius="4"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Margin="10,0"
                                                IsVisible="{Binding IsAdminBadge}">
                                            <TextBlock Text="ADMIN"
                                                       Foreground="{DynamicResource DeepBlackBrush}"
                                                       FontFamily="{DynamicResource FontInterBold}"
                                                       FontSize="10"
                                                       LetterSpacing="1"/>
                                        </Border>

                                        <!-- Badge user -->
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource SuccessForestLightBrush}"
                                                CornerRadius="4"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Margin="10,0"
                                                IsVisible="{Binding !IsAdminBadge}">
                                            <TextBlock Text="USER"
                                                       Foreground="{DynamicResource SuccessForestBrush}"
                                                       FontFamily="{DynamicResource FontInterBold}"
                                                       FontSize="10"
                                                       LetterSpacing="1"/>
                                        </Border>

                                        <!-- Bouton suppression -->
                                        <Button Grid.Column="2"
                                                Content="Supprimer"
                                                Command="{Binding $parent[ListBox].((vm:UsersViewModel)DataContext).DeleteUserCommand}"
                                                CommandParameter="{Binding Email}"
                                                Classes="danger"
                                                FontSize="11"
                                                Padding="14,7"
                                                MinHeight="32"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
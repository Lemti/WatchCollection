<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="700"
             x:Class="WatchCollection.Views.CollectionDetailsView"
             x:DataType="vm:CollectionDetailsViewModel">

    <Design.DataContext>
        <vm:CollectionDetailsViewModel/>
    </Design.DataContext>

    <Panel>
        <ScrollViewer>
            <StackPanel>
                <!-- En-tête -->
                <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,24">
                    <Button Content="← Retour"
                            Command="{Binding BackCommand}"
                            Classes="secondary"
                            Padding="14,8"
                            FontSize="12"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Détail de la montre"
                               Classes="title"
                               FontSize="28"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- MODE LECTURE -->
                <Border Classes="card-luxe"
                        IsVisible="{Binding !IsEditing}">
                    <StackPanel Spacing="20">
                        <Grid ColumnDefinitions="170,*">
                            <Border Background="{DynamicResource IvoryBrush}"
                                    CornerRadius="12"
                                    Height="150" Width="150"
                                    VerticalAlignment="Top">
                                <Panel>
                                    <Image Source="{Binding MyWatch.Picture}"
                                           Stretch="Uniform" Height="120" Width="120"
                                           IsVisible="{Binding MyWatch.Picture, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Text="⌚" FontSize="56"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ChampagneGoldBrush}"
                                               IsVisible="{Binding MyWatch.Picture, Converter={x:Static ObjectConverters.IsNull}}"/>
                                </Panel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="6" Margin="28,0,0,0">
                                <TextBlock Text="{Binding MyWatch.Brand}"
                                           FontFamily="{DynamicResource FontPlayfairBold}"
                                           FontSize="32"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding MyWatch.Model}"
                                           FontFamily="{DynamicResource FontPlayfair}"
                                           FontSize="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"/>

                                <Border Background="White"
                                        CornerRadius="10" Padding="20">
                                    <Grid ColumnDefinitions="120,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Référence" Classes="label" Margin="0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MyWatch.Reference}" Classes="value" Margin="0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Code-barre" Classes="label" Margin="0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MyWatch.Barcode}" Classes="value" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mouvement" Classes="label" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MyWatch.Movement}" Classes="value" Margin="0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Diamètre" Classes="label" Margin="0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MyWatch.Diameter, StringFormat={}{0} mm}" Classes="value" Margin="0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Boîtier" Classes="label" Margin="0,4"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MyWatch.CaseMaterial}" Classes="value" Margin="0,4"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Spacing="36" Margin="0,16,0,0">
                                    <StackPanel>
                                        <TextBlock Text="ANNÉE" Classes="section"/>
                                        <TextBlock Text="{Binding MyWatch.Year}"
                                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                                   FontSize="22"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="STOCK" Classes="section"/>
                                        <TextBlock Text="{Binding MyWatch.Stock}"
                                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                                   FontSize="22"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="PRIX" Classes="section"/>
                                        <TextBlock Text="{Binding MyWatch.Price, StringFormat={}{0:N0} €}"
                                                   FontFamily="{DynamicResource FontPlayfairBold}"
                                                   FontSize="26"
                                                   Foreground="{DynamicResource ChampagneGoldBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ParchmentLineBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Modifier"
                                    Command="{Binding StartEditCommand}"
                                    Classes="primary"/>
                            <Button Content="Supprimer"
                                    Command="{Binding RequestDeleteCommand}"
                                    Classes="danger"/>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{DynamicResource FontInter}"
                                   FontStyle="Italic"
                                   FontSize="12"
                                   Foreground="{DynamicResource SuccessForestBrush}"
                                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>

                <!-- MODE ÉDITION -->
                <Border Classes="card-luxe"
                        IsVisible="{Binding IsEditing}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="3" Height="22"
                                    Background="{DynamicResource ChampagneGoldBrush}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Modifier la montre"
                                       FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                       FontSize="22"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="MARQUE" Classes="section"/>
                                <TextBox Text="{Binding EditBrand}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="MODÈLE" Classes="section"/>
                                <TextBox Text="{Binding EditModel}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="RÉFÉRENCE" Classes="section"/>
                                <TextBox Text="{Binding EditReference}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="CODE-BARRE" Classes="section"/>
                                <TextBox Text="{Binding EditBarcode}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="MOUVEMENT" Classes="section"/>
                                <TextBox Text="{Binding EditMovement}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="DIAMÈTRE (mm)" Classes="section"/>
                                <TextBox Text="{Binding EditDiameter}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,16,*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="MATÉRIAU" Classes="section"/>
                                <TextBox Text="{Binding EditCaseMaterial}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="PRIX (€)" Classes="section"/>
                                <TextBox Text="{Binding EditPrice}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="ANNÉE" Classes="section"/>
                                <TextBox Text="{Binding EditYear}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="STOCK" Classes="section"/>
                            <TextBox Text="{Binding EditStock}" MaxWidth="160" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Content="Enregistrer"
                                    Command="{Binding SaveEditCommand}"
                                    Classes="success"/>
                            <Button Content="Annuler"
                                    Command="{Binding CancelEditCommand}"
                                    Classes="secondary"/>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{DynamicResource FontInter}"
                                   FontStyle="Italic"
                                   FontSize="12"
                                   Foreground="{DynamicResource WarningAmberBrush}"
                                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- OVERLAY DE CONFIRMATION DE FUSION -->
        <Border Background="#B0000000"
                IsVisible="{Binding IsMergeConfirmationVisible}">
            <Border Background="{DynamicResource CreamBrush}"
                    CornerRadius="14" Padding="32"
                    MaxWidth="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BoxShadow="0 8 32 0 #60000000">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="⚠"
                                   FontSize="26"
                                   Foreground="{DynamicResource WarningAmberBrush}"/>
                        <TextBlock Text="Doublon détecté"
                                   FontFamily="{DynamicResource FontPlayfairBold}"
                                   FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource ParchmentLineBrush}"/>

                    <TextBlock Text="{Binding MergeConfirmationText}"
                               FontFamily="{DynamicResource FontInter}"
                               FontSize="13"
                               LineHeight="22"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Annuler"
                                Command="{Binding CancelMergeCommand}"
                                Classes="secondary"/>
                        <Button Content="Confirmer la fusion"
                                Command="{Binding ConfirmMergeCommand}"
                                Classes="warning"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- OVERLAY DE CONFIRMATION DE SUPPRESSION -->
        <Border Background="#B0000000"
                IsVisible="{Binding IsDeleteConfirmationVisible}">
            <Border Background="{DynamicResource CreamBrush}"
                    CornerRadius="14" Padding="32"
                    MaxWidth="500"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BoxShadow="0 8 32 0 #60000000">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="⚠"
                                   FontSize="26"
                                   Foreground="{DynamicResource ErrorBordeauxBrush}"/>
                        <TextBlock Text="Confirmer la suppression"
                                   FontFamily="{DynamicResource FontPlayfairBold}"
                                   FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource ParchmentLineBrush}"/>

                    <TextBlock Text="{Binding DeleteConfirmationText}"
                               FontFamily="{DynamicResource FontInter}"
                               FontSize="13"
                               LineHeight="22"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Annuler"
                                Command="{Binding CancelDeleteCommand}"
                                Classes="secondary"/>
                        <Button Content="Supprimer définitivement"
                                Command="{Binding ConfirmDeleteCommand}"
                                Classes="danger"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
             x:Class="WatchCollection.Views.CollectionView"
             x:DataType="vm:CollectionViewModel"
             x:Name="Collection">

    <Design.DataContext>
        <vm:CollectionViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- En-tête -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Mes montres" Classes="title"/>
                <TextBlock Text="{Binding MyObservableWatches.Count, StringFormat={}{0} pièces dans la collection}"
                           FontFamily="{DynamicResource FontInter}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Importer"
                        Command="{Binding ImportCsvCommand}"
                        Classes="primary"/>
                <Button Content="Exporter"
                        Command="{Binding ToggleExportPanelCommand}"
                        Classes="secondary"/>
            </StackPanel>
        </Grid>

        <!-- Message de statut -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusMessage}"
                   FontFamily="{DynamicResource FontInter}"
                   FontStyle="Italic"
                   FontSize="12"
                   Foreground="{DynamicResource SuccessForestBrush}"
                   Margin="0,0,0,12"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- Panneau de sélection des colonnes à exporter -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,16"
                IsVisible="{Binding ShowExportPanel}">
            <StackPanel Spacing="12">
                <TextBlock Text="Sélectionnez les colonnes à exporter"
                           FontFamily="{DynamicResource FontPlayfairSemiBold}"
                           FontSize="16"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ItemsControl ItemsSource="{Binding ExportColumns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      Content="{Binding DisplayName}"
                                      FontFamily="{DynamicResource FontInter}"
                                      FontSize="13"
                                      Margin="0,0,16,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Exporter le CSV"
                            Command="{Binding ConfirmExportCommand}"
                            Classes="primary"/>
                    <Button Content="Annuler"
                            Command="{Binding ToggleExportPanelCommand}"
                            Classes="secondary"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Liste des montres -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding MyObservableWatches}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding ((vm:CollectionViewModel)DataContext).FromParentCommand, ElementName=Collection}"
                                CommandParameter="{Binding Id}"
                                Background="Transparent"
                                Padding="0" Margin="0,0,0,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Border Classes="card-watch">
                                <Grid ColumnDefinitions="90,*,Auto">

                                    <!-- Vignette image -->
                                    <Border Background="{DynamicResource IvoryBrush}"
                                            CornerRadius="8"
                                            Height="76" Width="76"
                                            VerticalAlignment="Center">
                                        <Panel>
                                            <Image Source="{Binding Picture}"
                                                   Stretch="Uniform" Height="64" Width="64"
                                                   IsVisible="{Binding Picture, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            <TextBlock Text="⌚" FontSize="32"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ChampagneGoldBrush}"
                                                       IsVisible="{Binding Picture, Converter={x:Static ObjectConverters.IsNull}}"/>
                                        </Panel>
                                    </Border>

                                    <!-- Infos centrales -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="16,0,0,0"
                                                Spacing="3">
                                        <TextBlock Text="{Binding Brand}"
                                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                                   FontSize="17"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Model}"
                                                   FontFamily="{DynamicResource FontInter}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Border Background="{DynamicResource IvoryBrush}"
                                                    CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding Movement}"
                                                           FontFamily="{DynamicResource FontInterMedium}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Diameter, StringFormat={}{0}mm}"
                                                       FontFamily="{DynamicResource FontInter}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Year}"
                                                       FontFamily="{DynamicResource FontInter}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Prix + chevron -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Margin="12,0,4,0">
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} €}"
                                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource ChampagneGoldBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="›"
                                                   FontSize="22"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
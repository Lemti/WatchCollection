<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WatchCollection.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="800"
             x:Class="WatchCollection.Views.ChartsView"
             x:DataType="vm:ChartsViewModel">

    <Design.DataContext>
        <vm:ChartsViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="20">
            <!-- En-tête -->
            <StackPanel>
                <TextBlock Text="Graphiques" Classes="title"/>
                <TextBlock Text="Vue d'ensemble analytique de votre collection"
                           FontFamily="{DynamicResource FontInter}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Pie charts côte à côte -->
            <Grid ColumnDefinitions="*,20,*">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="3" Height="18"
                                    Background="{DynamicResource ChampagneGoldBrush}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Stock par marque"
                                       FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:PieChart Series="{Binding BrandSeries}"
                                      LegendPosition="Bottom"
                                      Height="280"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="3" Height="18"
                                    Background="{DynamicResource ChampagneGoldBrush}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Types de mouvement"
                                       FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:PieChart Series="{Binding MovementSeries}"
                                      LegendPosition="Bottom"
                                      Height="280"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bar chart pleine largeur -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="3" Height="18"
                                Background="{DynamicResource ChampagneGoldBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Comparaison des prix"
                                   FontFamily="{DynamicResource FontPlayfairSemiBold}"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <lvc:CartesianChart Series="{Binding PriceSeries}"
                                        XAxes="{Binding PriceXAxes}"
                                        YAxes="{Binding PriceYAxes}"
                                        Height="380"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WatchCollection.App"
             xmlns:local="using:WatchCollection"
             RequestedThemeVariant="Light">

    <!-- DataTemplates : conservé tel quel (utilisé par Avalonia pour binder les VM aux Views) -->
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <!-- Resources : palette de couleurs + polices -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Palette.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <!-- Styles : FluentTheme de base + nos styles centralisés -->
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/AppStyles.axaml" />
    </Application.Styles>

</Application>